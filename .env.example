# Environment variables for IBM Quantum hardware runs (Phase 6).
# Copy this file to `.env` (or `.env.local`) at the repository root and fill
# in your own credentials. The `.env` file is gitignored and must NOT be
# committed.
#
# Phase 6 splits the 8 hardware batches across up to 3 IBM Cloud accounts.
# You only need to populate as many accounts as you actually plan to use.
# `src/phase_6/run_phase_6.py` reads these variables at runtime.
#
# Where to get the values:
#   - API token: https://quantum.cloud.ibm.com/  →  Account → API tokens
#   - CRN:       the "Instance" CRN string for your IBM Cloud Quantum service
#                instance (begins with `crn:v1:bluemix:public:quantum-computing:...`)

# Account 1 (required for any hardware run)
IBM_ACC1_API=replace_with_your_ibm_quantum_api_token
IBM_ACC1_CRN=replace_with_your_ibm_quantum_instance_crn

# Account 2 (optional, used by run_phase_6 --run-account 2)
IBM_ACC2_API=
IBM_ACC2_CRN=

# Account 3 (optional, used by run_phase_6 --run-account 3)
IBM_ACC3_API=
IBM_ACC3_CRN=
